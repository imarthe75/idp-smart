# =============================================================================
# idp-smart — CONFIGURACIÓN DE MOTORES HÍBRIDOS
# Proyecto Tolucón — Motor de Inferencia Modular
# =============================================================================
#
# ESQUEMA DE FASES:
#   Fase 1 (ACTIVA)   → OCR: Docling CPU  | LLM: Google Gemini Flash (cloud)
#   Fase 2            → OCR: Docling CPU  | LLM: VLLM local Dell (sin GPU aún)
#   Fase 3 (RunPod)   → OCR: Docling GPU  | LLM: VLLM RunPod L40S
#   Fase 4 (L40S)     → OCR: Docling CUDA | LLM: VLLM Dell L40S
#
# Para cambiar de fase: editar las variables de FASE ACTIVA y reiniciar worker.
# =============================================================================

# =============================================================================
# [1] SELECTOR DE MOTORES — FASE ACTIVA
# =============================================================================
#   OCR_ENGINE  : docling | google_doc_ai | aws_textract
#   LLM_PROVIDER: vllm | google | runpod | anthropic | openai

# --- MODOS DE EJECUCIÓN ---

# OPCIÓN A: Google Gemini Cloud (Rápido, requiere API Key)
# LLM_PROVIDER=google
# RUNPOD_ENABLED=false

# OPCIÓN B: RunPod vLLM (Alto rendimiento, escalable)
# LLM_PROVIDER=runpod
# RUNPOD_ENABLED=true

# OPCIÓN C: VLLM Local (Requiere GPU física local Dell)
# LLM_PROVIDER=vllm
# RUNPOD_ENABLED=false

# CONFIGURACIÓN ACTIVA POR DEFECTO:
OCR_ENGINE=docling
LLM_PROVIDER=google

# =============================================================================
# [2] GOOGLE GEMINI (Motor Cloud — Fase Actual)
# =============================================================================
GOOGLE_API_KEY=tu_api_key_de_google_aqui
# Flash = rápido y económico
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-1.5-pro-latest    # Pro = más preciso

# =============================================================================
# [3] MOTOR LOCAL — VLLM (Self-Hosted Dell)
# =============================================================================
# IP o Host del servidor local (usar 'localhost' para local, o la IP de red como 192.168.x.x)
LOCAL_SERVER_IP=localhost
LOCAL_API_URL=http://${LOCAL_SERVER_IP}:8000
LOCAL_LLM_MODEL=ibm-granite/granite-3.0-8b-instruct
LOCAL_LLM_TIMEOUT=300

# =============================================================================
# [4] RUNPOD — GESTIÓN DE CICLO DE VIDA (Power Control)
# =============================================================================
RUNPOD_ENABLED=false
RUNPOD_API_KEY=tu_runpod_api_key_aqui

# IDs de los Pods en RunPod (configurar cuando se creen los pods)
RUNPOD_POD_LLM_ID=xyz123abc456

# Segundos de inactividad antes de apagar el pod (ahorro de costo)
RUNPOD_IDLE_TIMEOUT=300

# =============================================================================
# [5] SMART ROUTER — Derivación automática a Cloud
# =============================================================================
# Si la cola Celery supera MAX_LOCAL_QUEUE tareas pendientes,
# el excedente se deriva a CLOUD_FALLBACK_PROVIDER.
ENABLE_CLOUD_FALLBACK=false
CLOUD_FALLBACK_PROVIDER=google
MAX_LOCAL_QUEUE=5

# =============================================================================
# [6] DOCLING — MODO CPU (Fase Actual)
# =============================================================================
DOCLING_CHUNK_SIZE=10

# Límite de cores para Docling/numpy (0 = auto-detect por hardware_detector)
OMP_NUM_THREADS=0
MKL_NUM_THREADS=0

# =============================================================================
# [7] MOTORES CLOUD ALTERNATIVOS
# =============================================================================
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# =============================================================================
# [8] BASE DE DATOS
# =============================================================================
DB_HOST=db
DB_PORT=5432
DB_USER=admin_user
DB_PASSWORD=tu_password_segura_aqui
DB_NAME=rpp

# =============================================================================
# [9] INFRAESTRUCTURA
# =============================================================================
VALKEY_URL=redis://valkey:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=minio_password123
MINIO_BUCKET=idp-documents

# =============================================================================
# [10] MODELOS MULTIMODAL Y VISION OPTIMIZER
# =============================================================================
MODEL_VISION_NAME=Qwen/Qwen2-VL-7B-Instruct-AWQ
MODEL_REASONING_NAME=ibm-granite/granite-3.0-8b-instruct
VISION_PARALLEL_WORKERS=1
VISION_DEVICE=auto
VISION_GPU_LAYERS=0
