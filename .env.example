# =============================================================================
# idp-smart — CONFIGURACIÓN MAESTRA DE MOTORES HÍBRIDOS
# =============================================================================

# [1] SELECTORES DE MOTOR — CONFIGURACIÓN ACTIVA
# ─────────────────────────────────────────────────────────────────────────────
# Motores OCR disponibles: docling | google | aws | azure
OCR_ENGINE=docling

# Proveedores LLM (Razonamiento): google | vllm | runpod | anthropic | openai | ollama
LLM_PROVIDER=google

# Smart Router: Si la cola local supera este límite, deriva a la nube
ENABLE_CLOUD_FALLBACK=true
CLOUD_FALLBACK_PROVIDER=google
MAX_LOCAL_QUEUE=10

# [2] GOOGLE DOCAI & GEMINI (CLOUD)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=tu_api_key_aqui
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Configuración Document AI (si OCR_ENGINE=google)
GOOGLE_DOCAI_PROJECT_ID=my-project-id
GOOGLE_DOCAI_LOCATION=us
GOOGLE_DOCAI_PROCESSOR_ID=abc123processor

# [3] AWS TEXTRACT (CLOUD)
# ─────────────────────────────────────────────────────────────────────────────
# Se requiere si OCR_ENGINE=aws
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=secret...
AWS_REGION=us-east-1

# [4] AZURE DOCUMENT INTELLIGENCE (CLOUD)
# ─────────────────────────────────────────────────────────────────────────────
# Se requiere si OCR_ENGINE=azure
AZURE_DOC_ENDPOINT=https://tu-recurso.cognitiveservices.azure.com/
AZURE_DOC_KEY=tu_azure_key_aqui

# [5] RUNPOD — GESTIÓN DE GPU EN LA NUBE
# ─────────────────────────────────────────────────────────────────────────────
RUNPOD_ENABLED=false
RUNPOD_API_KEY=rpa_...

# IDs de los Pods (para control de encendido/apagado automático)
RUNPOD_POD_LLM_ID=pod_id_aqui
RUNPOD_POD_VISION_ID=pod_id_aqui
RUNPOD_POD_DOCLING_ID=pod_id_aqui

# URLs de los Proxys (si no se usan, se autodetectan vía API si el pod está ON)
# RUNPOD_LLM_URL=https://podid-11434.proxy.runpod.net/v1
# RUNPOD_VISION_URL=https://podid-8000.proxy.runpod.net/v1
# RUNPOD_DOCLING_URL=https://podid-8000.proxy.runpod.net

# [6] MOTOR LOCAL — DELL SERVER (CPU / GPU L40S)
# ─────────────────────────────────────────────────────────────────────────────
# Configuración Docling (Fase actual CPU)
# 'auto' ajusta dinámicamente según la RAM del servidor
DOCLING_CHUNK_SIZE=auto 
OMP_NUM_THREADS=0
MKL_NUM_THREADS=0
WORKER_CONCURRENCY=1

# Configuración VLLM Local
LOCAL_SERVER_IP=localhost
LOCAL_API_URL=http://${LOCAL_SERVER_IP}:8000
LOCAL_LLM_MODEL=granite-3.0-8b-instruct
LOCAL_LLM_TIMEOUT=300

# [7] OLLAMA — RAZONAMIENTO LOCAL
# ─────────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite3.1-dense:8b

# [8] VISIÓN ANALÍTICA & CACHE
# ─────────────────────────────────────────────────────────────────────────────
# Si es True, ignora Docling y envía imágenes directamente a Gemini Multimodal
VISION_SKIP_LOCAL_OCR=false

# Si es True, recupera análisis visuales previos de MinIO (Ahorro de costos)
VISION_USE_CACHE=true

# [9] INFRAESTRUCTURA (DOCKER / PRODUCCIÓN)
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_USER=admin_user
DB_PASSWORD=Ad54=Tx91.Vm+23_Qr78
DB_NAME=rpp

VALKEY_URL=redis://valkey:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=minio_password123
MINIO_BUCKET=idp-documents

# [10] OTROS PROVEEDORES CLOUD (LLM)
# ─────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-5-sonnet-20241022

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
